# API Keys for Real-Time Travel Data

# Amadeus API (FREE - 2000 requests/month)
# Get your key at: https://developers.amadeus.com/register
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# RapidAPI Key (FREE tier available)
# Get your key at: https://rapidapi.com/
# Used for: Skyscanner, Booking.com, Hotels.com APIs
RAPIDAPI_KEY=your_rapidapi_key_here

# SerpAPI (100 free searches/month)
# Get your key at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Alternative: Aviationstack for flight data
# Get your key at: https://aviationstack.com/
AVIATIONSTACK_KEY=your_aviationstack_key_here

# Server Configuration
PORT=3001
NODE_ENV=development
